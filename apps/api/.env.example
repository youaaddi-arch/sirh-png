# API
NODE_ENV=development
PORT=4000
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ARGON2_PEPPER=change-me-in-production
TOTP_ISSUER=SIRH-PN

# Database
DATABASE_URL=postgresql://sirh:sirh_dev_pwd@localhost:5432/sirh_dev?schema=public

# Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-3
S3_ACCESS_KEY=sirh
S3_SECRET_KEY=sirh_dev_pwd
S3_BUCKET_DOCUMENTS=sirh-documents
S3_BUCKET_CONTRACTS=sirh-contracts
S3_BUCKET_PAYSLIPS=sirh-payslips
S3_BUCKET_PREBOARDING=sirh-preboarding

# Mail (dev: MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sirh-png.local

# AI (Claude) — laissé vide en S0, activé en S3
ANTHROPIC_API_KEY=

# Web app base URL (for links in emails)
WEB_BASE_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
