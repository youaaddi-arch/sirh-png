{
  "name": "sirh-png",
  "version": "2.0.0-sprint0",
  "private": true,
  "description": "SIRH multi-entités Paris Nord Groupe — référence Eurecia",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "db:down": "docker compose -f infrastructure/docker-compose.yml down",
    "db:reset": "docker compose -f infrastructure/docker-compose.yml down -v && pnpm db:up",
    "db:migrate": "pnpm --filter @sirh/api prisma migrate dev",
    "db:seed": "pnpm --filter @sirh/api prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
